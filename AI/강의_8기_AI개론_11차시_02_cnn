        "# eval_loss(손실계산)\n",
        "\n",
        "def eval_loss(loader, device, net, criterion):\n",
        "    for images, labels in loader:\n",
        "        break\n",
        "\n",
        "    # device 할당\n",
        "    inputs = images.to(device)\n",
        "    labels = labels.to(device)\n",
        "\n",
        "    # 예측\n",
        "    outputs = net(inputs)\n",
        "\n",
        "    # 손실 계산\n",
        "    loss = criterion(outputs, labels)\n",
        "\n",
        "    return loss"
      ],
